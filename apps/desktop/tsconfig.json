{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/main/**/*.ts",
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/renderer/**/*.d.ts",
    "vite.config.ts"
  ],
  "exclude": ["src/renderer/**/*.test.ts", "src/renderer/**/*.test.tsx"]
}
